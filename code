function mx {
    local exec=1
    local fast="-Ofast -Wall -Wextra -march=native -mtune=native -flto"
    local valgrind=0
    local args=""
    local OPTIND

    while getopts "f v o c a h" opt; do
        case $opt in
            f) fast="-Ofast -DNDEBUG -Wall -Wextra -march=native -mtune=native -flto" ;;
            o) fast="-O0";;
            v) valgrind=1;;
            c) exec=0;;
            a) read -p "Saisir le ou les argument(s) : " args;;
            h) echo "Options valides :"
               echo "   -f : Ajoute -DNDEBUG lors de la compilation"
               echo "   -v : execute le code dans Valgrind"
               echo "   -o : ajoute l'option -O0 lors de la compilation pour que gcc ne modifie pas le code"
               echo "   -c : ne fait que compiler"
               echo "   -a : passe des arguments lors de l'execution. Metrre des guillemets autour des arguments s'il y en a plusieurs"
               echo "   -h : affiche ce message"
               return 0 ;;
            \?) echo "option invalide. -h pour la liste des options."
                return 1 ;;
        esac
    done
    
    shift $((OPTIND - 1))

    local nom_prog=${1/.c/}
    gcc "${@:1}" $fast -lm -g -o $nom_prog
    if [ $exec -eq 1 ]; then
        if [ $valgrind -eq 0 ]; then
            ./"$nom_prog" $args
        else
            valgrind --leak-check=full --show-leak-kinds=all --track-origins=yes -s ./"$nom_prog" $args
            if [ -f vgcore.* ]; then
                rm vgcore.*
            fi
        fi
        rm $nom_prog
    fi
}

function go {
    while getopts "h" opt; do
        case $opt in
            h) echo "Utilisation : go tp 11, go dm 2, go tp_p 17..."
               echo "Ouvre le dossier donnĂ© en argument (en mettant des majuscules) dans VS Code, puis s'il y a un .pdf l'ouvre (il faut qu'il ait le mĂŞme nom que le dossier)."
               echo "tp correspond aux tp d'info, tp_p Ă  ceux de physique"
               return 0 ;;
            \?) echo "option invalide. -h pour la liste des options."
                return 1 ;;
        esac
    done
    
    shift $((OPTIND - 1))

    local type=$1
    local nb=""
    if [ $# -eq 1 ]; then
        if [ $type = "tp" ]; then
            nb=$(cat ~/.fct/var/der_TP.txt)
        else
            nb=$(cat ~/.fct/var/der_DM.txt)
        fi
    else
        nb=$2
        echo $nb > ~/.fct/var/der_TP.txt
    fi

    case $type in
        'tp')
            z ~/Documents/prepa/info/TP/
            if [ -d TP$nb ]; then
            else mkdir "TP$nb"
            fi
                
            code "TP$nb"
            z TP$nb
            if [ -f "TP$nb.pdf" ]; then
                evince "TP$nb.pdf" & disown
            fi;;
        'tp_p')
            z ~/Documents/prepa/physique/TP/
            if [ -d TP$nb ]; then
            else mkdir "TP$nb"
            fi
                
            code "TP$nb"
            z TP$nb
            if [ -f "TP$nb.pdf" ]; then
                evince "TP$nb.pdf" & disown
            fi;;
        'dm')
            z ~/Documents/prepa/info/DM/
            if [ -d DM$nb ]; then
            else mkdir "TP$nb"
            fi

            code "DM$nb"
            z DM$nb
            if [ -f "DM$nb.pdf" ]; then
                evince "DM$nb.pdf" & disown
            fi ;;
        \?) echo "Argument de la mauvaise forme. -h pour l'aide."
            return 1;;
    esac
}

function push {
    local repo="main"
    local change=0
    while getopts "r" opt; do
        case $opt in
            r) repo=$1
               change=1 ;;
            \?) echo "option invalide. -h pour la liste des options."
                return 1 ;;
        esac
    done
    
    shift $((OPTIND - 1))
    if [ $# -eq 0 ]; then
        echo "Il faut le commentaire !"
        return 1
    fi
    git add .
    echo $change
    if [ $change -eq 0 ]; then
        git commit -m $1
        git push origin main
    else
        git commit -m $2
        git push origin $1
    fi
    return 0
}

function colle {
    z ~/Documents/prepa/Maths/colles
    local num=1
    if [ $# -eq 1 ]; then
        num=$1
    else
        while [ -f "sem${num}.pdf" ]
        do
            let num=$(($num+1))
        done
        let num=$(($num-1))
    fi
    evince sem${num}.pdf & disown
    kill -9 $PPID
}

