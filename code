function mx {
    local fast="-Ofast"
    local valgrind=0
    local OPTIND

    while getopts "f v o h l" opt; do
        case $opt in
            f) fast="-Ofast -DNDEBUG" ;;
            o) fast="-O0";;
            v) valgrind=1;;
            h) echo "Options valides :"
               echo "   -f : Ajoute les options -Ofast et -DNDEBUG lors de la compilation pour un executable plus rapide"
               echo "   -v : execute le code dans Valgrind"
               echo "   -o : ajoute l'option -O0 lors de la compilation pour que gcc ne modifie pas le code"
               echo "   -h : affiche ce message"
               return 0 ;;
            \?) echo "option invalide. -h pour la liste des options."
                return 1 ;;
        esac
    done
    
    shift $((OPTIND - 1))

    local nom_prog=${1/.c/}
    case ${1: -1} in
        'c' ) gcc "${@:1}" -Wall -Wextra $fast -lm -g -o $nom_prog
        if [ $valgrind -eq 0 ]; then
            ./"$nom_prog"
        else
            valgrind --leak-check=full --show-leak-kinds=all --track-origins=yes ./"$nom_prog"
        fi
        rm $nom_prog ;;
        'y' ) /bin/python3 $1;;
    esac
}

function go {
    while getopts "h" opt; do
        case $opt in
            h) echo "Utilisation : go tp11, go dm2..."
               echo "Va dans le dossier ~/Documents/prepa/info, puis dans DM/ si le premier argument commence par dm ou DM, TP/ si ça commence par tp ou TP."
               echo "Ouvre le dossier donné en argument (en mettant des majuscules) dans VS Code, puis s'il y a un .pdf l'ouvre (il faut qu'il ait le même nom que le dossier)."
               return 0 ;;
            \?) echo "option invalide. -h pour la liste des options."
                return 1 ;;
        esac
    done
    
    shift $((OPTIND - 1))
    cd ~/Documents/prepa/info
    local type=${1:0:2}
    local nb=${1:2}
    case $type in
        'tp') cd TP/
              if [ -d TP$nb ]; then
                code "TP$nb"
                cd TP$nb
                if [ -f "TP$nb.pdf" ]; then
                    evince "TP$nb.pdf" & disown
                fi
              else
                mkdir "TP$nb"
                code TP$nb
                cd TP$nb
              fi ;;
        'dm') cd DM/
              code "DM$nb"
              cd DM$nb
              if [ -f "DM$nb.pdf" ]; then
                  evince "DM$nb.pdf" &
              fi ;;
        \?) echo "Argument de la mauvaise forme. -h pour l'aide."
            return 1;;
    esac
}

function push {
    local repo="main"
    local change=0
    while getopts "r" opt; do
        case $opt in
            r) repo=$1
               change=1 ;;
            \?) echo "option invalide. -h pour la liste des options."
                return 1 ;;
        esac
    done
    
    shift $((OPTIND - 1))
    if [ $# -eq 0 ]; then
        echo "Il faut le commentaire !"
        return 1
    fi
    git add .
    echo $change
    if [ $change -eq 0 ]; then
        git commit -m $1
        git push origin main
    else
        git commit -m $2
        git push origin $1
    fi
    return 0
}

